# Sanity configuration
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_READ_TOKEN=
SANITY_STUDIO_BASE_PATH=/studio
SANITY_PREVIEW_SECRET=
SANITY_WEBHOOK_SECRET=
SANITY_STUDIO_PREVIEW_BASE_URL=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# Public app URL and customer auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=
ORDER_ACCESS_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
EMAIL_SERVER=
EMAIL_FROM=

# Airalo catalog sync
AIRALO_CLIENT_ID=
AIRALO_CLIENT_SECRET=
AIRALO_BASE_URL=https://partners-api.airalo.com/v2
AIRALO_PACKAGES_SEND_CREDENTIALS=false
AIRALO_BRAND_SETTINGS_NAME=
AIRALO_SYNC_CRON_TOKEN=
AIRALO_SYNC_ALERT_EMAIL=
# Optional override. Async order submissions append ?airalo_webhook_secret=...
# for Simplify's webhook authentication.
AIRALO_ASYNC_WEBHOOK_URL=
# Required for async orders. Simplify-owned URL token for Airalo webhook
# callbacks. Prefer a URL-safe random value and keep it separate from
# ORDER_ACCESS_SECRET.
AIRALO_WEBHOOK_SECRET=
AIRALO_RECOVERY_STALE_MINUTES=10
AIRALO_RECOVERY_ALERT_AFTER_MINUTES=45
AIRALO_RECOVERY_BATCH_SIZE=25
AIRALO_SMOKE_ICCID=

# DPO payments
DPO_COMPANY_TOKEN=
DPO_SERVICE_TYPE=
DPO_SERVICE_URL=https://secure.3gdirectpay.com/API/v6
DPO_PAYMENT_URL=https://secure.3gdirectpay.com
DPO_IPN_SECRET=

# Email delivery and alerts
RESEND_API_KEY=
ALERT_EMAIL_FROM=alerts@simplify.africa
RECEIPT_EMAIL_FROM=receipts@simplify.africa

# Admin authentication
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_ALLOWED_EMAILS=

# Observability
METRICS_BEARER_TOKEN=

# Database
DATABASE_URL=
# Optional Prisma pool tuning for serverless/session-pooled Postgres
PRISMA_CONNECTION_LIMIT=1
PRISMA_POOL_TIMEOUT=20
